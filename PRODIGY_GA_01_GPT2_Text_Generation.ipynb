        "from transformers import pipeline\n",
        "\n",
        "generator = pipeline(\"text-generation\", model=\"gpt2\")\n",
        "\n",
        "result = generator(\n",
        "    \"Artificial Intelligence is\",\n",
        "    max_length=50,\n",
        "    num_return_sequences=1\n",
        ")\n",
        "\n",
        "print(result[0][\"generated_text\"])"
      ],
